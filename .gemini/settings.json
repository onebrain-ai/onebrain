{
  "model": {
    "disableLoopDetection": true
  },
  "hooks": {
    "AfterAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "onebrain checkpoint stop --json > /dev/null 2>&1; echo '{}'"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "write_file|replace",
        "hooks": [
          {
            "type": "command",
            "command": "onebrain qmd reindex --json > /dev/null 2>&1; echo '{}'"
          }
        ]
      }
    ]
  }
}
